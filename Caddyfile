www.curiator.net {
	redir https://curiator.net{uri} permanent
}

curiator.net {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), geolocation=(), payment=()"
	}

	route {
		@gallery_no_slash path /gallery
		redir @gallery_no_slash /gallery/ 308

		@gallery_index path /gallery/
		handle @gallery_index {
			root * /srv/curiator.net
			rewrite * /gallery/index.html
			header Cache-Control "no-cache"
			file_server
		}

		redir /gallery/sietch /gallery/sietch/ 308
		redir /gallery/aviato /gallery/aviato/ 308
		redir /gallery/geometry /gallery/geometry/ 308
		redir /gallery/ot /gallery/ot/ 308

		handle /gallery/sietch/* {
			reverse_proxy 127.0.0.1:8210
		}

		handle /gallery/aviato/* {
			reverse_proxy 127.0.0.1:8310
		}

		handle /gallery/geometry/* {
			reverse_proxy 127.0.0.1:8420
		}

		handle /gallery/ot/* {
			reverse_proxy 127.0.0.1:8430
		}

		@site_assets path /site-assets/*
		header @site_assets Cache-Control "public, max-age=604800"

		handle {
			root * /srv/curiator.net
			header Cache-Control "no-cache"
			file_server {
				hide Caddyfile README.md .git
			}
		}
	}

	log {
		output file /var/log/caddy/curiator.net-access.log {
			roll_size 20MiB
			roll_keep 5
			roll_keep_for 168h
		}
		format json
	}
}
